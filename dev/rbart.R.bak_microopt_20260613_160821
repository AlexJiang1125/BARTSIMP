# =============================================================================
# Minimal R BART supporting heteroskedastic observation precisions Omega_i
# =============================================================================
# This is a prototype-grade implementation of the Chipman-George-McCulloch BART
# sampler with grow + prune Metropolis-Hastings moves. Designed to be plugged
# into an outer Gibbs sampler that provides PG-augmented pseudo-data
# (pseudo_y, Omega) each sweep.
#
# Model (conditional on Omega, ignoring spatial part):
#   pseudo_y_i ~ N(sum_l g(x_i; T_l, mu_l), Omega_i^{-1})
#   mu_b | T   ~ N(0, tau^2)              for each leaf b
#   T          ~ Chipman 1998 prior: P(non-terminal at depth d) = alpha (1+d)^(-beta)
#
# Tree representation: a list of equal-length vectors indexed by node id.
#   parent, left, right, depth, is_leaf, split_var, split_val, mu
# Node ids are positions 1..length(tree$parent). Root is always id 1.
# =============================================================================

# -----------------------------------------------------------------------------
# Empty tree (single root leaf with mu = init_val)
# -----------------------------------------------------------------------------
new_tree <- function(init_mu = 0) {
  list(
    parent    = NA_integer_,
    left      = NA_integer_,
    right     = NA_integer_,
    depth     = 0L,
    is_leaf   = TRUE,
    split_var = NA_integer_,
    split_val = NA_real_,
    mu        = init_mu
  )
}

# -----------------------------------------------------------------------------
# Walk obs down the tree; return leaf node id for each row of X.
# Vectorized level-synchronous descent: bit-identical to a per-row scalar walk
# (strict `<` at each split), ~12x faster. Requires X to be a matrix.
# -----------------------------------------------------------------------------
tree_leaf_assign <- function(tree, X) {
  n   <- nrow(X)
  cur <- rep.int(1L, n)
  isleaf <- tree$is_leaf
  repeat {
    internal <- !isleaf[cur]
    if (!any(internal)) break
    idx  <- which(internal)
    node <- cur[idx]
    goleft <- X[cbind(idx, tree$split_var[node])] < tree$split_val[node]
    cur[idx] <- ifelse(goleft, tree$left[node], tree$right[node])
  }
  cur
}

# Fitted value per row
tree_predict <- function(tree, X) tree$mu[tree_leaf_assign(tree, X)]

# -----------------------------------------------------------------------------
# Leaf marginal log-likelihood (mu integrated out) under N(0, tau^2) prior,
# heteroskedastic precisions Omega_i, leaf residuals r_i.
# Returns log p(r_leaf) up to terms not depending on the tree partition.
# Specifically returns the partition-dependent part:
#   -1/2 log(1 + tau^2 S_b) + 1/2 tau^2 (sum_i Omega_i r_i)^2 / (1 + tau^2 S_b)
# -----------------------------------------------------------------------------
leaf_marglik <- function(r, Omega, tau2) {
  S <- sum(Omega)
  q <- sum(Omega * r)
  -0.5 * log1p(tau2 * S) + 0.5 * tau2 * q^2 / (1 + tau2 * S)
}

# -----------------------------------------------------------------------------
# Tree prior log probability of being a leaf vs not at depth d
# -----------------------------------------------------------------------------
log_p_nonterm <- function(d, alpha = 0.95, beta = 2) {
  log(alpha) - beta * log1p(d)
}
log_p_term <- function(d, alpha = 0.95, beta = 2) {
  log1p(-alpha * (1 + d)^(-beta))
}

# -----------------------------------------------------------------------------
# Add two child leaves to a leaf node, turning it into an internal node.
# Returns the new tree (with two extra rows appended).
# -----------------------------------------------------------------------------
tree_grow_at <- function(tree, node_id, split_var, split_val, mu_left, mu_right) {
  n_nodes <- length(tree$parent)
  left_id  <- n_nodes + 1L
  right_id <- n_nodes + 2L
  d_new <- tree$depth[node_id] + 1L
  tree$parent    <- c(tree$parent,    node_id, node_id)
  tree$left      <- c(tree$left,      NA_integer_, NA_integer_)
  tree$right     <- c(tree$right,     NA_integer_, NA_integer_)
  tree$depth     <- c(tree$depth,     d_new, d_new)
  tree$is_leaf   <- c(tree$is_leaf,   TRUE, TRUE)
  tree$split_var <- c(tree$split_var, NA_integer_, NA_integer_)
  tree$split_val <- c(tree$split_val, NA_real_,    NA_real_)
  tree$mu        <- c(tree$mu,        mu_left, mu_right)

  tree$is_leaf[node_id]   <- FALSE
  tree$split_var[node_id] <- split_var
  tree$split_val[node_id] <- split_val
  tree$left[node_id]      <- left_id
  tree$right[node_id]     <- right_id
  tree$mu[node_id]        <- NA_real_
  tree
}

# Reverse: turn a NOG (no-grandchildren-internal) back into a leaf, drop its two children.
# Children must currently be the *last two* node ids appended; if not, we reindex.
# Generic version: remove rows at positions (left_id, right_id) and reindex parent/left/right.
tree_prune_at <- function(tree, nog_id, mu_collapsed) {
  l <- tree$left[nog_id]
  r <- tree$right[nog_id]
  drop <- sort(c(l, r), decreasing = TRUE)  # remove higher index first

  for (j in drop) {
    keep <- seq_along(tree$parent) != j
    tree <- lapply(tree, function(v) v[keep])
    # reindex all references > j down by 1
    bump <- function(x) ifelse(!is.na(x) & x > j, x - 1L, x)
    tree$parent <- bump(tree$parent)
    tree$left   <- bump(tree$left)
    tree$right  <- bump(tree$right)
    # also bump nog_id if needed
    if (!is.na(nog_id) && nog_id > j) nog_id <- nog_id - 1L
  }
  tree$is_leaf[nog_id]   <- TRUE
  tree$split_var[nog_id] <- NA_integer_
  tree$split_val[nog_id] <- NA_real_
  tree$left[nog_id]      <- NA_integer_
  tree$right[nog_id]     <- NA_integer_
  tree$mu[nog_id]        <- mu_collapsed
  tree
}

# -----------------------------------------------------------------------------
# Identify candidate splits in a leaf:
#   For each variable, find the unique x-values present in this leaf;
#   cuts are unique-values except the smallest (so both sides get >=1 obs).
# Returns a list per variable of available cut values (length 0 if not splittable).
# -----------------------------------------------------------------------------
leaf_splittable <- function(X_leaf) {
  apply(X_leaf, 2, function(col) {
    u <- sort(unique(col))
    if (length(u) < 2) numeric(0) else u[-1]
  }, simplify = FALSE)
}

# -----------------------------------------------------------------------------
# Grow move: returns list(tree, accepted, log_alpha)
# r and Omega are vectors of length n (residual, precision) for ALL observations.
# X is n x p.
# tau2 is the leaf-mu prior variance.
# -----------------------------------------------------------------------------
tree_grow <- function(tree, X, r, Omega, tau2,
                      alpha = 0.95, beta = 2,
                      P_grow = 0.5, P_prune = 0.5,
                      var_probs = NULL) {
  leaf_assign <- tree_leaf_assign(tree, X)
  leaves <- which(tree$is_leaf)
  n_leaves <- length(leaves)
  # Pick a leaf uniformly at random
  leaf_id <- leaves[sample.int(n_leaves, 1)]
  obs_idx <- which(leaf_assign == leaf_id)
  if (length(obs_idx) < 2) return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))

  # Find splittable vars in this leaf
  X_leaf <- X[obs_idx, , drop = FALSE]
  cuts_per_var <- leaf_splittable(X_leaf)
  n_cuts_per_var <- vapply(cuts_per_var, length, integer(1))
  splittable_vars <- which(n_cuts_per_var > 0)
  if (length(splittable_vars) == 0) return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))

  # Pick splitting variable. When var_probs is NULL, uniform among splittables.
  # Otherwise use Linero (2018)'s DART weights restricted to splittable vars.
  if (is.null(var_probs)) {
    var <- splittable_vars[sample.int(length(splittable_vars), 1)]
    log_q_var_fwd <- -log(length(splittable_vars))
  } else {
    w <- var_probs[splittable_vars]
    w <- w / sum(w)
    var <- sample(splittable_vars, 1, prob = w)
    log_q_var_fwd <- log(w[match(var, splittable_vars)])
  }
  cuts <- cuts_per_var[[var]]
  cut <- cuts[sample.int(length(cuts), 1)]

  # Partition leaf obs
  left_idx  <- obs_idx[X_leaf[, var] <  cut]
  right_idx <- obs_idx[X_leaf[, var] >= cut]
  if (length(left_idx) == 0 || length(right_idx) == 0) {
    return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))
  }

  # Marginal likelihood ratio
  L_parent <- leaf_marglik(r[obs_idx],   Omega[obs_idx],   tau2)
  L_left   <- leaf_marglik(r[left_idx],  Omega[left_idx],  tau2)
  L_right  <- leaf_marglik(r[right_idx], Omega[right_idx], tau2)
  log_lik_ratio <- L_left + L_right - L_parent

  # Tree prior ratio
  d_parent <- tree$depth[leaf_id]
  log_prior_ratio <- log_p_nonterm(d_parent, alpha, beta) +
                     2 * log_p_term(d_parent + 1, alpha, beta) -
                     log_p_term(d_parent, alpha, beta)

  # Transition ratio: log q(old|new) - log q(new|old)
  #   forward grow:    P_grow * (1/n_leaves) * P(var) * (1/n_cuts_for_var)
  #   reverse prune:   P_prune * (1/n_nogs_new)
  # log q(old|new) - log q(new|old)
  #   = log(P_prune) - log(P_grow) + log(n_leaves) - log_q_var_fwd
  #     + log(n_cuts_for_var) - log(n_nogs_new)
  n_nogs_new <- sum_nogs_after_grow(tree, leaf_id)
  log_trans_ratio <- log(P_prune) - log(P_grow) +
                     log(n_leaves) -
                     log_q_var_fwd +
                     log(length(cuts)) -
                     log(n_nogs_new)

  log_alpha <- log_lik_ratio + log_prior_ratio + log_trans_ratio
  if (is.finite(log_alpha) && log(runif(1)) < log_alpha) {
    new_tree <- tree_grow_at(tree, leaf_id, var, cut, mu_left = 0, mu_right = 0)
    return(list(tree = new_tree, accepted = TRUE, log_alpha = log_alpha))
  }
  list(tree = tree, accepted = FALSE, log_alpha = log_alpha)
}

# Helper: count NOGs (internal nodes whose both children are leaves)
tree_nogs <- function(tree) {
  internal <- which(!tree$is_leaf)
  if (length(internal) == 0) return(integer(0))
  internal[ vapply(internal, function(j) {
    tree$is_leaf[tree$left[j]] && tree$is_leaf[tree$right[j]]
  }, logical(1)) ]
}

# After growing at leaf_id, how many NOGs would the new tree have?
# leaf_id becomes an internal node with two leaf children, so it's a NOG.
# Any previously-NOG node whose child set still has two leaves stays a NOG.
# Growing only converts leaf_id into a NOG (and may remove its parent from NOGs
# if leaf_id was the only leaf-child that made parent a NOG-with-this-leaf, but
# actually NOG requires BOTH children to be leaves; if parent was a NOG then
# both its children were leaves including leaf_id, so after leaf_id is split,
# parent is no longer a NOG).
sum_nogs_after_grow <- function(tree, leaf_id) {
  current <- tree_nogs(tree)
  parent_of_leaf <- tree$parent[leaf_id]
  # Was parent_of_leaf a NOG before?
  was_parent_nog <- !is.na(parent_of_leaf) && parent_of_leaf %in% current
  # New tree: leaf_id is now a NOG; parent_of_leaf no longer is (if it was)
  length(current) + 1L - as.integer(was_parent_nog)
}

# -----------------------------------------------------------------------------
# Prune move
# -----------------------------------------------------------------------------
tree_prune <- function(tree, X, r, Omega, tau2,
                       alpha = 0.95, beta = 2,
                       P_grow = 0.5, P_prune = 0.5,
                       var_probs = NULL) {
  nogs <- tree_nogs(tree)
  if (length(nogs) == 0) return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))

  nog_id <- nogs[sample.int(length(nogs), 1)]
  l_id <- tree$left[nog_id]; r_id <- tree$right[nog_id]
  leaf_assign <- tree_leaf_assign(tree, X)
  left_idx  <- which(leaf_assign == l_id)
  right_idx <- which(leaf_assign == r_id)
  obs_idx   <- c(left_idx, right_idx)

  # Marginal likelihood ratio (collapse children into parent)
  L_parent <- leaf_marglik(r[obs_idx],   Omega[obs_idx],   tau2)
  L_left   <- leaf_marglik(r[left_idx],  Omega[left_idx],  tau2)
  L_right  <- leaf_marglik(r[right_idx], Omega[right_idx], tau2)
  log_lik_ratio <- L_parent - L_left - L_right

  # Tree prior ratio (reciprocal of grow's)
  d_nog <- tree$depth[nog_id]
  log_prior_ratio <- log_p_term(d_nog, alpha, beta) -
                     log_p_nonterm(d_nog, alpha, beta) -
                     2 * log_p_term(d_nog + 1, alpha, beta)

  # Transition ratio: log q(old|new) - log q(new|old)
  # Forward prune: P_prune * (1/n_nogs)
  # Reverse grow:  P_grow  * (1/n_leaves_new) * P(var_used) * (1/n_cuts_for_var)
  X_collapsed <- X[obs_idx, , drop = FALSE]
  cuts_per_var <- leaf_splittable(X_collapsed)
  n_cuts_per_var <- vapply(cuts_per_var, length, integer(1))
  splittable_vars <- which(n_cuts_per_var > 0)
  var_used <- tree$split_var[nog_id]
  n_cuts_for_var <- length(cuts_per_var[[var_used]])

  if (is.null(var_probs)) {
    log_q_var_rev <- -log(length(splittable_vars))
  } else {
    w <- var_probs[splittable_vars]
    w <- w / sum(w)
    idx <- match(var_used, splittable_vars)
    log_q_var_rev <- if (is.na(idx)) -Inf else log(w[idx])
  }

  n_leaves_new <- sum(tree$is_leaf) - 1L
  log_trans_ratio <- log(P_grow) - log(P_prune) -
                     log(n_leaves_new) +
                     log_q_var_rev -
                     log(n_cuts_for_var) +
                     log(length(nogs))

  log_alpha <- log_lik_ratio + log_prior_ratio + log_trans_ratio
  if (is.finite(log_alpha) && log(runif(1)) < log_alpha) {
    new_tree <- tree_prune_at(tree, nog_id, mu_collapsed = 0)
    return(list(tree = new_tree, accepted = TRUE, log_alpha = log_alpha))
  }
  list(tree = tree, accepted = FALSE, log_alpha = log_alpha)
}

# -----------------------------------------------------------------------------
# Combined birth-death step
#
# Subtlety in the MH ratio:
#   - In tree_grow, the "P_grow" arg is the forward proposal rate (P at current
#     tree); "P_prune" is the reverse proposal rate (P at the NEW tree).
#   - Similarly in tree_prune.
#   At the root-only state, forward grow is forced (rate = 1) but the reverse
#   rate from any grown tree is the canonical 0.5 (because the grown tree has
#   both NOGs and leaves).
#   At a tree-with-one-NOG state, forward prune is rate P_prune; reverse grow
#   from the resulting root-only state has rate 1.
# -----------------------------------------------------------------------------
tree_bd <- function(tree, X, r, Omega, tau2,
                    alpha = 0.95, beta = 2,
                    P_grow_default = 0.5,
                    var_probs = NULL) {
  P_prune_default <- 1 - P_grow_default
  n_internal <- sum(!tree$is_leaf)

  if (n_internal == 0) {
    return(tree_grow(tree, X, r, Omega, tau2, alpha, beta,
                     P_grow = 1.0, P_prune = P_prune_default,
                     var_probs = var_probs))
  }

  if (runif(1) < P_grow_default) {
    tree_grow(tree, X, r, Omega, tau2, alpha, beta,
              P_grow = P_grow_default, P_prune = P_prune_default,
              var_probs = var_probs)
  } else {
    P_grow_reverse <- if (n_internal == 1) 1.0 else P_grow_default
    tree_prune(tree, X, r, Omega, tau2, alpha, beta,
               P_grow = P_grow_reverse, P_prune = P_prune_default,
               var_probs = var_probs)
  }
}

# -----------------------------------------------------------------------------
# Gibbs draw of leaf mu's given current tree structure. Returns the leaf
# assignment too, so the caller can build the fit without re-walking the tree.
# -----------------------------------------------------------------------------
tree_draw_mu <- function(tree, X, r, Omega, tau2) {
  leaf_assign <- tree_leaf_assign(tree, X)
  leaves <- which(tree$is_leaf)
  # split() keeps every leaf incl. empty ones (sum 0 -> prior draw), matching
  # the old per-leaf which() loop; rnorm over the vector consumes draws in leaf
  # order == L scalar rnorm(1) calls, so seeded runs stay bit-identical.
  g    <- factor(leaf_assign, levels = leaves)
  S    <- vapply(split(Omega,     g), sum, numeric(1))
  q    <- vapply(split(Omega * r, g), sum, numeric(1))
  prec <- 1 / tau2 + S
  tree$mu[leaves] <- rnorm(length(leaves), q / prec, 1 / sqrt(prec))
  list(tree = tree, leaf = leaf_assign)
}

# -----------------------------------------------------------------------------
# Ensemble prediction
# (Note: lapply has its own `X` argument — we wrap to avoid the name clash.)
# -----------------------------------------------------------------------------
ensemble_predict <- function(ensemble, X) {
  Reduce(`+`, lapply(ensemble, function(t) tree_predict(t, X)))
}

# -----------------------------------------------------------------------------
# One Gibbs sweep through the ensemble:
#   For each tree: subtract its fit, do BD move, Gibbs draw mu's, add back.
# pseudo_y: pseudo-response after PG and spatial subtraction (i.e. ybar* - z)
# Omega: per-obs precision
# Returns updated ensemble + acceptance count.
# -----------------------------------------------------------------------------
ensemble_sweep <- function(ensemble, X, pseudo_y, Omega, tau2,
                           alpha = 0.95, beta = 2, P_grow = 0.5,
                           var_probs = NULL) {
  m <- length(ensemble)
  fits <- lapply(ensemble, function(t) tree_predict(t, X))
  total <- Reduce(`+`, fits)
  accepts <- 0L
  for (j in seq_len(m)) {
    r_j <- pseudo_y - (total - fits[[j]])
    out <- tree_bd(ensemble[[j]], X, r_j, Omega, tau2, alpha, beta, P_grow,
                  var_probs = var_probs)
    dm <- tree_draw_mu(out$tree, X, r_j, Omega, tau2)
    ensemble[[j]] <- dm$tree
    new_fit <- dm$tree$mu[dm$leaf]   # reuse leaf assignment (mu draw left it unchanged)
    total <- total - fits[[j]] + new_fit
    fits[[j]] <- new_fit
    accepts <- accepts + as.integer(out$accepted)
  }
  list(ensemble = ensemble, fit = total, accepts = accepts)
}

# =============================================================================
# Path A (BD marginal) functions
# =============================================================================
# tree_bd_marginal / tree_grow_marginal / tree_prune_marginal: mirror the
# tree_bd / tree_grow / tree_prune machinery, but the BD MH ratio uses the
# Path A marginal log-likelihood (integrating both mu_l and z analytically)
# instead of the closed-form leaf marginal that conditions on z.
#
# These require A (SPDE projection), Qu_chol (cached Cholesky of Q_u), m_u0
# (cached posterior-mean of u given r) -- prepared once per tree update by
# ensemble_sweep_marginal().
#
# `r` is the cluster-level residual AFTER subtracting other trees but NOT z.
# =============================================================================

tree_grow_marginal <- function(tree, X, r, Omega, A, Qu_chol, m_u0, tau2,
                               alpha = 0.95, beta = 2,
                               P_grow = 0.5, P_prune = 0.5,
                               var_probs = NULL) {
  leaf_assign_curr <- tree_leaf_assign(tree, X)
  leaves <- which(tree$is_leaf)
  n_leaves <- length(leaves)
  leaf_id <- leaves[sample.int(n_leaves, 1)]
  obs_idx <- which(leaf_assign_curr == leaf_id)
  if (length(obs_idx) < 2)
    return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))

  X_leaf <- X[obs_idx, , drop = FALSE]
  cuts_per_var <- leaf_splittable(X_leaf)
  n_cuts_per_var <- vapply(cuts_per_var, length, integer(1))
  splittable_vars <- which(n_cuts_per_var > 0)
  if (length(splittable_vars) == 0)
    return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))

  if (is.null(var_probs)) {
    var <- splittable_vars[sample.int(length(splittable_vars), 1)]
    log_q_var_fwd <- -log(length(splittable_vars))
  } else {
    w <- var_probs[splittable_vars]; w <- w / sum(w)
    var <- sample(splittable_vars, 1, prob = w)
    log_q_var_fwd <- log(w[match(var, splittable_vars)])
  }
  cuts <- cuts_per_var[[var]]
  cut <- cuts[sample.int(length(cuts), 1)]

  left_idx  <- obs_idx[X_leaf[, var] <  cut]
  right_idx <- obs_idx[X_leaf[, var] >= cut]
  if (length(left_idx) == 0 || length(right_idx) == 0)
    return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))

  # Proposed leaf assignment: split the chosen leaf into two
  max_leaf_id <- max(leaf_assign_curr)
  leaf_assign_prop <- leaf_assign_curr
  leaf_assign_prop[left_idx]  <- max_leaf_id + 1L
  leaf_assign_prop[right_idx] <- max_leaf_id + 2L

  # Marginal mlik for current and proposed
  f_curr <- margprob_marginal_pathA(leaf_assign_curr, r, Omega, A, Qu_chol, m_u0, tau2)
  f_prop <- margprob_marginal_pathA(leaf_assign_prop, r, Omega, A, Qu_chol, m_u0, tau2)
  if (!is.finite(f_curr) || !is.finite(f_prop))
    return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))
  log_lik_ratio <- f_prop - f_curr

  d_parent <- tree$depth[leaf_id]
  log_prior_ratio <- log_p_nonterm(d_parent, alpha, beta) +
                     2 * log_p_term(d_parent + 1, alpha, beta) -
                     log_p_term(d_parent, alpha, beta)

  n_nogs_new <- sum_nogs_after_grow(tree, leaf_id)
  log_trans_ratio <- log(P_prune) - log(P_grow) +
                     log(n_leaves) - log_q_var_fwd +
                     log(length(cuts)) - log(n_nogs_new)

  log_alpha <- log_lik_ratio + log_prior_ratio + log_trans_ratio
  if (is.finite(log_alpha) && log(runif(1)) < log_alpha) {
    new_tree <- tree_grow_at(tree, leaf_id, var, cut, mu_left = 0, mu_right = 0)
    return(list(tree = new_tree, accepted = TRUE, log_alpha = log_alpha))
  }
  list(tree = tree, accepted = FALSE, log_alpha = log_alpha)
}

tree_prune_marginal <- function(tree, X, r, Omega, A, Qu_chol, m_u0, tau2,
                                alpha = 0.95, beta = 2,
                                P_grow = 0.5, P_prune = 0.5,
                                var_probs = NULL) {
  nogs <- tree_nogs(tree)
  if (length(nogs) == 0)
    return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))

  nog_id <- nogs[sample.int(length(nogs), 1)]
  l_id <- tree$left[nog_id]; r_id <- tree$right[nog_id]
  leaf_assign_curr <- tree_leaf_assign(tree, X)
  left_idx  <- which(leaf_assign_curr == l_id)
  right_idx <- which(leaf_assign_curr == r_id)
  obs_idx   <- c(left_idx, right_idx)

  # Proposed leaf assignment: merge the two children into one
  max_leaf_id <- max(leaf_assign_curr)
  leaf_assign_prop <- leaf_assign_curr
  leaf_assign_prop[obs_idx] <- max_leaf_id + 1L

  f_curr <- margprob_marginal_pathA(leaf_assign_curr, r, Omega, A, Qu_chol, m_u0, tau2)
  f_prop <- margprob_marginal_pathA(leaf_assign_prop, r, Omega, A, Qu_chol, m_u0, tau2)
  if (!is.finite(f_curr) || !is.finite(f_prop))
    return(list(tree = tree, accepted = FALSE, log_alpha = -Inf))
  log_lik_ratio <- f_prop - f_curr

  d_nog <- tree$depth[nog_id]
  log_prior_ratio <- log_p_term(d_nog, alpha, beta) -
                     log_p_nonterm(d_nog, alpha, beta) -
                     2 * log_p_term(d_nog + 1, alpha, beta)

  # Transition: see tree_prune for derivation
  X_collapsed    <- X[obs_idx, , drop = FALSE]
  cuts_per_var   <- leaf_splittable(X_collapsed)
  n_cuts_per_var <- vapply(cuts_per_var, length, integer(1))
  splittable_vars <- which(n_cuts_per_var > 0)
  var_used        <- tree$split_var[nog_id]
  n_cuts_for_var  <- length(cuts_per_var[[var_used]])
  if (is.null(var_probs)) {
    log_q_var_rev <- -log(length(splittable_vars))
  } else {
    w <- var_probs[splittable_vars]; w <- w / sum(w)
    idx <- match(var_used, splittable_vars)
    log_q_var_rev <- if (is.na(idx)) -Inf else log(w[idx])
  }
  n_leaves_new <- sum(tree$is_leaf) - 1L
  log_trans_ratio <- log(P_grow) - log(P_prune) -
                     log(n_leaves_new) +
                     log_q_var_rev -
                     log(n_cuts_for_var) +
                     log(length(nogs))

  log_alpha <- log_lik_ratio + log_prior_ratio + log_trans_ratio
  if (is.finite(log_alpha) && log(runif(1)) < log_alpha) {
    new_tree <- tree_prune_at(tree, nog_id, mu_collapsed = 0)
    return(list(tree = new_tree, accepted = TRUE, log_alpha = log_alpha))
  }
  list(tree = tree, accepted = FALSE, log_alpha = log_alpha)
}

tree_bd_marginal <- function(tree, X, r, Omega, A, Qu_chol, m_u0, tau2,
                             alpha = 0.95, beta = 2,
                             P_grow_default = 0.5,
                             var_probs = NULL) {
  P_prune_default <- 1 - P_grow_default
  n_internal <- sum(!tree$is_leaf)
  if (n_internal == 0) {
    return(tree_grow_marginal(tree, X, r, Omega, A, Qu_chol, m_u0, tau2,
                              alpha, beta,
                              P_grow = 1.0, P_prune = P_prune_default,
                              var_probs = var_probs))
  }
  if (runif(1) < P_grow_default) {
    tree_grow_marginal(tree, X, r, Omega, A, Qu_chol, m_u0, tau2, alpha, beta,
                       P_grow = P_grow_default, P_prune = P_prune_default,
                       var_probs = var_probs)
  } else {
    P_grow_reverse <- if (n_internal == 1) 1.0 else P_grow_default
    tree_prune_marginal(tree, X, r, Omega, A, Qu_chol, m_u0, tau2, alpha, beta,
                        P_grow = P_grow_reverse, P_prune = P_prune_default,
                        var_probs = var_probs)
  }
}

# Sweep through ensemble using Path A BD moves.
#   pseudo_y : pseudo-response (= ybar* in PG notation)        length n_cl
#   Omega    : per-cluster precision                           length n_cl
#   z_current: current draw of z (subtracted from residual for mu Gibbs only)
#   A, spde, sigma_m, rho: to build Q_u
ensemble_sweep_marginal <- function(ensemble, X, pseudo_y, Omega, z_current, tau2,
                                    A, Q_psi,
                                    alpha = 0.95, beta = 2, P_grow = 0.5,
                                    var_probs = NULL) {
  m <- length(ensemble)
  fits  <- lapply(ensemble, function(t) tree_predict(t, X))
  total <- Reduce(`+`, fits)

  # Q_u and Cholesky factor cached for all BD evaluations in this sweep
  AtWA <- Matrix::crossprod(A, as.vector(Omega) * A)
  Qu   <- Matrix::forceSymmetric(AtWA + Q_psi)
  Qu_chol <- Matrix::Cholesky(Qu, LDL = FALSE, super = FALSE, perm = FALSE)

  accepts <- 0L
  for (j in seq_len(m)) {
    # Residual for BD: NO z subtraction (z is integrated out)
    r_j_no_z <- pseudo_y - (total - fits[[j]])

    # m_u0 for this tree's residual
    rhs    <- as.numeric(Matrix::crossprod(A, Omega * r_j_no_z))
    m_u0_j <- as.numeric(Matrix::solve(Qu_chol, rhs, system = "A"))

    # BD move with marginal mlik
    out <- tree_bd_marginal(ensemble[[j]], X, r_j_no_z, Omega,
                            A, Qu_chol, m_u0_j, tau2,
                            alpha, beta, P_grow, var_probs)

    # Gibbs draw leaf mu's GIVEN z_current  (same closed form as Path B)
    r_j_with_z <- r_j_no_z - z_current
    dm <- tree_draw_mu(out$tree, X, r_j_with_z, Omega, tau2)
    ensemble[[j]] <- dm$tree

    new_fit <- dm$tree$mu[dm$leaf]   # reuse leaf assignment (mu draw left it unchanged)
    total <- total - fits[[j]] + new_fit
    fits[[j]] <- new_fit
    accepts <- accepts + as.integer(out$accepted)
  }
  list(ensemble = ensemble, fit = total, accepts = accepts)
}

# -----------------------------------------------------------------------------
# Count splitting-variable usage across all trees in an ensemble
# -----------------------------------------------------------------------------
ensemble_var_usage <- function(ensemble, P) {
  counts <- integer(P)
  for (tree in ensemble) {
    splits <- tree$split_var[!tree$is_leaf]
    splits <- splits[!is.na(splits)]
    if (length(splits) > 0) counts <- counts + tabulate(splits, nbins = P)
  }
  counts
}

# -----------------------------------------------------------------------------
# DART variable-inclusion probability update (Linero, 2018).
#   p ~ Dirichlet(alpha_dart / P, ..., alpha_dart / P)
#   p | counts ~ Dirichlet(counts_v + alpha_dart / P)
# Smaller alpha_dart -> stronger sparsity.
# -----------------------------------------------------------------------------
update_var_probs_dart <- function(ensemble, P, alpha_dart = 1.0) {
  counts <- ensemble_var_usage(ensemble, P)
  shape <- counts + alpha_dart / P
  gam <- rgamma(P, shape = shape, rate = 1)
  gam / sum(gam)
}

# -----------------------------------------------------------------------------
# Initialize an ensemble of m single-root trees with mu = init_val / m
# -----------------------------------------------------------------------------
ensemble_init <- function(m, init_val = 0) {
  replicate(m, new_tree(init_mu = init_val / m), simplify = FALSE)
}
